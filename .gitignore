# Terraform state — NEVER commit
*.tfstate
*.tfstate.*
*.tfstate.backup

# Crash logs
crash.log
crash.*.log

# Variable files (may contain secrets)
*.tfvars
*.tfvars.json
!example.tfvars

# Provider plugin cache
.terraform/
.terraform.lock.hcl.bak

# Plan output files
tfplan
*.tfplan

# CLI config
.terraformrc
terraform.rc

# OS
.DS_Store
